<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- لون الخلفية -->
    <solid android:color="#FFFFFF"/>

    <!-- الحافة / الحدود -->
    <stroke
        android:width="2dp"
        android:color="#A8D2D2FD"/>

    <!-- زوايا مستديرة -->
    <corners android:radius="8dp"/>

    <!-- حشوة داخلية -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp"/>
</shape>